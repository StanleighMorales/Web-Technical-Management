# Local Development
VITE_API_BASE_URL=http://localhost:5278

# Production (Railway)
# VITE_API_BASE_URL=https://your-backend-url.railway.app

# Token keys for authentication
VITE_ACCESS_TOKEN_KEY=your-access-token-key
VITE_REFRESH_TOKEN_KEY=your-refresh-token-key

# Image Storage URL (S3 bucket, CDN, or static file server)
# Examples:
# - S3: https://your-bucket.s3.amazonaws.com
# - Cloudflare R2: https://your-bucket.r2.cloudflarestorage.com
# - Local: http://localhost:5278/uploads
VITE_IMAGE_BASE_URL=https://your-bucket-url.com
